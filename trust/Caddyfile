:80 {
    # Serve landing page (llm.openautonomyx.com)
    handle /trust* {
        root * /srv/trust
        file_server
        try_files {path} {path}/index.html
    }
    handle {
        root * /srv
        file_server
        try_files {path} {path}/index.html
    }

    encode gzip

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Health check endpoint
    respond /health 200
}
