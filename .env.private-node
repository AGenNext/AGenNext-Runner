# .env.private-node
# ─────────────────────────────────────────────────────────────────────────────
# Autonomyx Model Gateway — Private Node Customer Environment
#
# Fill in the values marked YOUR_* before running docker compose.
# Values marked [PROVIDED BY AUTONOMYX] are given to you during onboarding.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway ───────────────────────────────────────────────────────────────────
# [PROVIDED BY AUTONOMYX] during private node onboarding
LITELLM_MASTER_KEY=sk-autonomyx-YOUR_MASTER_KEY
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=YOUR_LITELLM_UI_PASSWORD

# ── Postgres (local, spend logs only) ────────────────────────────────────────
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# ── Langfuse (your traces go to Autonomyx Langfuse, your org) ────────────────
# [PROVIDED BY AUTONOMYX] — scoped to your tenant organisation
LANGFUSE_PUBLIC_KEY=pk-lf-YOUR_PUBLIC_KEY
LANGFUSE_SECRET_KEY=sk-lf-YOUR_SECRET_KEY
LANGFUSE_HOST=https://traces.openautonomyx.com

# ── Grafana (local dashboard) ─────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD

# ── Langflow ──────────────────────────────────────────────────────────────────
LANGFLOW_DB_PASSWORD=YOUR_LANGFLOW_DB_PASSWORD
LANGFLOW_SECRET_KEY=YOUR_LANGFLOW_SECRET          # openssl rand -hex 32
LANGFLOW_ADMIN_EMAIL=admin@yourcompany.com
LANGFLOW_ADMIN_PASSWORD=YOUR_LANGFLOW_PASSWORD
# [PROVIDED BY AUTONOMYX] — your LiteLLM virtual key for spend tracking
LANGFLOW_VIRTUAL_KEY=sk-autonomyx-YOUR_VIRTUAL_KEY

# ── Ollama memory limits — SET BASED ON YOUR VPS RAM ─────────────────────────
#
# 16GB VPS:  OLLAMA_MEM_LIMIT=10g  MAX_LOADED=1  → runs 7B/8B models
# 32GB VPS:  OLLAMA_MEM_LIMIT=20g  MAX_LOADED=2  → runs 14B always-on
# 64GB VPS:  OLLAMA_MEM_LIMIT=45g  MAX_LOADED=3  → runs 32B always-on
# 96GB VPS:  OLLAMA_MEM_LIMIT=70g  MAX_LOADED=4  → full primary stack
#
OLLAMA_MEM_LIMIT=20g
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=2
OLLAMA_KEEP_ALIVE=24h
